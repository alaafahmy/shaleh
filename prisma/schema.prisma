generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = "postgresql://neondb_owner:npg_0tpwrTs4XeWN@ep-restless-bird-aph57d64-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
  directUrl = "postgresql://neondb_owner:npg_0tpwrTs4XeWN@ep-restless-bird-aph57d64-pooler.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require&pgbouncer=true&connect_timeout=15"
}

model User {
  id           String        @id @default(cuid())
  name         String
  username     String        @unique
  password     String        // In a real app, this should be hashed
  role         String        @default("استقبال") // 'admin', 'reservation_manager', 'accountant', 'receptionist', 'maintenance'
  roleAr       String        // Arabic role name
  active       Boolean       @default(true)
  ref_number   String        @unique @default(cuid())
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  reservations Reservation[] @relation("CreatedReservations")
  payments     Payment[]     @relation("CreatedPayments")
  expenses     Expense[]     @relation("CreatedExpenses")
  maintenances Maintenance[] @relation("CreatedMaintenances")
  auditLogs    AuditLog[]
}

model Chalet {
  id            String        @id
  name          String
  type          String        // 'صغير', 'كبير', 'VIP'
  pricePerNight Float
  status        String        @default("متاح") // 'متاح', 'محجوز', 'تحت الصيانة'
  description   String?
  colorIndex    Int           @default(1)
  ref_number    String        @unique @default(cuid())
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  reservations  Reservation[]
  expenses      Expense[]
  maintenances  Maintenance[]
  revenues      Revenue[]
}

model Client {
  id          String        @id @default(cuid())
  name        String
  phone       String        @unique
  nationalId  String?
  notes       String?
  is_archived Boolean       @default(false)
  ref_number  String        @unique @default(cuid())
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  reservations Reservation[]
}

model Reservation {
  id            String    @id @default(cuid())
  client        Client    @relation(fields: [clientId], references: [id])
  clientId      String
  chalet        Chalet    @relation(fields: [chaletId], references: [id])
  chaletId      String
  checkIn       DateTime
  checkOut      DateTime
  nights        Int
  pricePerNight Float
  totalCost     Float
  status        String    @default("معلق") // 'معلق', 'مؤكد', 'مكتمل', 'ملغي'
  notes         String?
  ref_number    String    @unique @default(cuid())
  
  createdBy     User      @relation("CreatedReservations", fields: [created_by], references: [id])
  created_by    String
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  payments      Payment[]
  revenues      Revenue[]
}

model Payment {
  id            String      @id @default(cuid())
  reservation   Reservation @relation(fields: [reservationId], references: [id])
  reservationId String
  amount        Float
  method        String      // 'نقد', 'تحويل بنكي', 'شبكة (مدى/Visa)'
  note          String?
  date          DateTime    @default(now())
  ref_number    String      @unique @default(cuid())
  
  createdBy     User        @relation("CreatedPayments", fields: [created_by], references: [id])
  created_by    String

  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  revenue       Revenue?
}

model Expense {
  id            String       @id @default(cuid())
  type          String       // 'صيانة', 'نظافة', 'كهرباء', 'ماء', 'رواتب'
  amount        Float
  chalet        Chalet?      @relation(fields: [chaletId], references: [id])
  chaletId      String?
  description   String
  date          DateTime     @default(now())
  
  maintenance   Maintenance? @relation(fields: [maintenanceId], references: [id])
  maintenanceId String?      @unique
  ref_number    String       @unique @default(cuid())

  createdBy     User         @relation("CreatedExpenses", fields: [created_by], references: [id])
  created_by    String

  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

model Maintenance {
  id            String    @id @default(cuid())
  chalet        Chalet    @relation(fields: [chaletId], references: [id])
  chaletId      String
  type          String
  cost          Float
  date          DateTime  @default(now())
  status        String    @default("جارية") // 'جارية', 'مكتملة'
  notes         String?
  completedDate DateTime?
  ref_number    String    @unique @default(cuid())

  expense       Expense?
  
  createdBy     User      @relation("CreatedMaintenances", fields: [created_by], references: [id])
  created_by    String

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Notification {
  id          String   @id @default(cuid())
  title       String
  description String
  priority    String   @default("low") // 'low', 'medium', 'high'
  read        Boolean  @default(false)
  date        DateTime @default(now())
  type        String   // 'reservation', 'expense', 'maintenance', 'system'
  
  createdAt   DateTime @default(now())
}

model Revenue {
  id             String      @id @default(cuid())
  reservation_id String
  reservation    Reservation @relation(fields: [reservation_id], references: [id])
  payment_id     String      @unique
  payment        Payment     @relation(fields: [payment_id], references: [id])
  chalet_id      String
  chalet         Chalet      @relation(fields: [chalet_id], references: [id])
  amount         Float
  revenue_date   DateTime    @default(now())
  ref_number     String      @unique @default(cuid())
}

model AuditLog {
  id             String   @id @default(cuid())
  user_id        String
  user           User     @relation(fields: [user_id], references: [id])
  action         String
  table_affected String
  record_id      String
  old_value      Json?
  new_value      Json?
  timestamp      DateTime @default(now())
}
